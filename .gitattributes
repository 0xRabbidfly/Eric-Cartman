# Normalize line endings: store text as LF in the repo, auto-detect binaries.
* text=auto

# Keep Windows-native scripts as CRLF so they run correctly on Windows.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Force LF for shell scripts.
*.sh text eol=lf

# Treat common binary assets as binary (no normalization).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
